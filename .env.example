# ─────────────────────────────────────────────────────────────────────────────
# SOUK FASHION HOUSE — Environment Variables
# Copy this to .env.local and fill in all values
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from: https://console.neon.tech → Connection String
# Use the "Pooled" connection for DATABASE_URL
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Use the "Direct" (non-pooled) for DATABASE_URL_UNPOOLED (required for Prisma migrations)
DATABASE_URL_UNPOOLED="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# For local dev: http://localhost:3000
# For production: https://soukfashionhouse.com
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use test keys for dev (rzp_test_...), live keys for production (rzp_live_...)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
# This is exposed to the browser — safe, only the Key ID not Secret
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxx"

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Resend (Email) ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# Replaces EmailJS from original project
RESEND_API_KEY="re_xxxxxxxxxx"

# ── WhatsApp (Preserved from original) ───────────────────────────────────────
# Include country code without +: India = 91
NEXT_PUBLIC_WHATSAPP_NUMBER="919999999999"
